# ============================================
# Core Runtime
# ============================================
PORT=3068
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://downloadtool:replace-with-strong-password@127.0.0.1:5432/downloadtool
RUST_API_URL=http://127.0.0.1:3068
REDIS_URL=redis://127.0.0.1:6379
SHARED_PROXY_POSTGRES_PASSWORD=replace-with-strong-password
# Optional shared proxy state. When set, proxy inventory + proxy health use these
# instead of the local app DATABASE_URL / REDIS_URL. This lets local dev share the
# same proxy fleet with production while keeping users/jobs local.
PROXY_DATABASE_URL=
PROXY_REDIS_URL=
PROXY_QUARANTINE_TTL_SECS=172800
# Local dev should point to the project-local Docker services started by `pnpm dev:db`.
# Do not point local dev to shared Redis services such as `server-redis`.
# Optional: file path to store quarantined (blocked) proxies, one record per line.
# Default: /tmp/downloadtool-quarantined-proxies.txt
PROXY_QUARANTINE_FILE=/tmp/downloadtool-quarantined-proxies.txt
ORIGIN=http://localhost:5168

# ============================================
# Durable Mux Jobs
# ============================================
MUX_QUEUE_STREAM=mux_jobs
MUX_ARTIFACT_BACKEND=localfs
MUX_DIRECT_DOWNLOAD=false
MUX_JOB_MAX_ATTEMPTS=3
MUX_FILE_TICKET_TTL_SECS=900
MUX_JOB_OUTPUT_DIR=/tmp/downloadtool-worker-artifacts
MUX_ARTIFACT_TTL_SECS=86400
MUX_CLEANUP_INTERVAL_SECS=3600
MUX_CLEANUP_BATCH_LIMIT=50
MUX_QUEUE_GROUP=mux-workers
MUX_WORKER_LEASE_SECS=90
MUX_WORKER_RECLAIM_LIMIT=100
MUX_WORKER_ID=

# ============================================
# S3 / MinIO / Cloudflare R2 (required when MUX_ARTIFACT_BACKEND=minio|r2)
# ============================================
S3_ENDPOINT=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_FORCE_PATH_STYLE=false

# ============================================
# Auth / Subscription
# ============================================
BETTER_AUTH_SECRET=replace-with-random-32-char-secret
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5168
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
WHOP_PLAN_ID=your-whop-plan-id
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret

# ============================================
# Frontend Public Config
# ============================================
VITE_API_URL=http://127.0.0.1:3068
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
PUBLIC_ADSTERRA_KEY=your-adsterra-key-here
PUBLIC_ENABLE_INTERSTITIAL=true
PUBLIC_ENABLE_BANNERS=true
PUBLIC_DEBUG=false
PUBLIC_MOCK_API=false

# Limits moved to config/runtime-limit-profiles.json (local / production objects).

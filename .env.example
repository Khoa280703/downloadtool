# ============================================
# Core Runtime
# ============================================
PORT=3068
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://downloadtool:replace-with-strong-password@127.0.0.1:5432/downloadtool
RUST_API_URL=http://127.0.0.1:3068
ORIGIN=http://localhost:5168

# ============================================
# Auth / Subscription
# ============================================
BETTER_AUTH_SECRET=replace-with-random-32-char-secret
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5168
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
WHOP_PLAN_ID=your-whop-plan-id
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret

# ============================================
# Frontend Public Config
# ============================================
VITE_API_URL=http://127.0.0.1:3068
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
PUBLIC_ADSTERRA_KEY=your-adsterra-key-here
PUBLIC_ENABLE_INTERSTITIAL=true
PUBLIC_ENABLE_BANNERS=true
PUBLIC_DEBUG=false
PUBLIC_MOCK_API=false

# Limits moved to config/runtime-limit-profiles.json (local / production objects).

# ============================================
# yt-dlp Extraction Tuning
# ============================================
# Semicolon-separated fallback extractor args list (tried after default profile).
# Example:
# YTDLP_FALLBACK_EXTRACTOR_ARGS="youtube:player_client=android,web;youtube:player_client=web_safari"
YTDLP_FALLBACK_EXTRACTOR_ARGS=

# Preferred JS runtimes order for YouTube JS decipher/ejs handling.
# Default in code: deno,node
YTDLP_JS_RUNTIMES=

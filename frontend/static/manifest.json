{
  "name": "Snapvie",
  "short_name": "Snapvie",
  "description": "Download YouTube videos, playlists, and audio in the best quality",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#111827",
  "theme_color": "#ff4d8c",
  "lang": "en",
  "icons": [
    {
      "src": "/logo.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/favicon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/favicon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "text": "url"
    }
  }
}

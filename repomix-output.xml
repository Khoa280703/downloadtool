		lt: 'Lietuvių',
		lv: 'Latviešu',
		nb: 'Norsk Bokmål',
		nl: 'Nederlands',
		pl: 'Polski',
		pt: 'Português',
		'pt-BR': 'Português (Brasil)',
		ro: 'Română',

<script lang="ts">
	type ChartItem = {
		label: string;
		value: number;
		tone?: 'neutral' | 'blue' | 'green' | 'amber' | 'red';
	};

	let {
		title,
		description = '',
		items
	}: {
		title: string;
		description?: string;
		items: ChartItem[];
	} = $props();

	const maxValue = $derived(Math.max(...items.map((item) => item.value), 1));

	function toneClass(tone: ChartItem['tone']): string {
		switch (tone) {
			case 'blue':
				return 'bg-blue-600';
			case 'green':
				return 'bg-emerald-600';
			case 'amber':
				return 'bg-amber-600';
			case 'red':
				return 'bg-rose-600';
			default:
				return 'bg-slate-500';
		}
	}

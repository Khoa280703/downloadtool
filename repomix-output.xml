    /// Feature not implemented.
    #[error("Feature not implemented")]
    NotImplemented,

    /// Stream fetch error.
    #[error("Stream fetch error: {0}")]
    StreamFetchError(String),

    /// Invalid codec.
    #[error("Invalid codec: {0}")]
    InvalidCodec(String),

    /// Proxy error.
    #[error("Proxy error: {0}")]
    ProxyError(String),
}

/// Segment information for a muxed fragment.

    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({ error: 'Unknown error' }));
      alert(`[DownloadTool] Extraction failed: ${err.error ?? res.statusText}`);
      resetButton();
      return;
    }

    const data = await res.json();
    const title: string = data.metadata?.title ?? 'video';

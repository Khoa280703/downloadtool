    .ok_or_else(|| MuxerError::InvalidInput("No moov in video stream".into()))?;
let audio_moov = find_box(&audio_data, b"moov")
    .ok_or_else(|| MuxerError::InvalidInput("No moov in audio stream".into()))?;

// Merge moov

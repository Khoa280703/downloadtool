				</p>
			</div>

			<div class="cookie-actions">
				<button class="btn-accept" onclick={handleAccept}>{m.cookie_banner_accept_all()}</button>
				<button class="btn-reject" onclick={handleReject}>{m.cookie_banner_reject_non_essential()}</button>
				<button
					class="btn-details"

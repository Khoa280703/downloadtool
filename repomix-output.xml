/** Map codec string prefix to human-readable label */
function getCodecLabel(codecs: string, isAudioOnly: boolean): string {
  if (isAudioOnly) {
    if (codecs.includes('mp4a')) return 'AAC';
    if (codecs.includes('opus')) return 'Opus';

services:
  postgres:
    image: postgres:16-alpine
    container_name: downloadtool-postgres
    environment:
      - POSTGRES_DB=downloadtool
      - POSTGRES_USER=downloadtool
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
    volumes:
      - postgres-data:/var/lib/postgresql/data
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    container_name: downloadtool-redis
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - redis-data:/data
    restart: unless-stopped

  api:
    build:
      context: .
      dockerfile: docker/Dockerfile.api
    container_name: downloadtool-api
    environment:
      - PORT=3068
      - RUST_LOG=info
      - PROXY_QUARANTINE_FILE=/app/proxy-state/quarantined-proxies.txt
      - DATABASE_URL=postgres://downloadtool:${POSTGRES_PASSWORD}@postgres:5432/downloadtool
      - REDIS_URL=redis://redis:6379
      - MUX_QUEUE_STREAM=${MUX_QUEUE_STREAM}
      - MUX_ARTIFACT_BACKEND=${MUX_ARTIFACT_BACKEND}
      - MUX_FILE_TICKET_TTL_SECS=${MUX_FILE_TICKET_TTL_SECS}
      - MUX_DIRECT_DOWNLOAD=${MUX_DIRECT_DOWNLOAD}
      - S3_ENDPOINT=${S3_ENDPOINT}
      - S3_BUCKET_NAME=${S3_BUCKET_NAME}
      - S3_ACCESS_KEY_ID=${S3_ACCESS_KEY_ID}
      - S3_SECRET_ACCESS_KEY=${S3_SECRET_ACCESS_KEY}
      - S3_REGION=${S3_REGION}
      - BETTER_AUTH_SECRET=${BETTER_AUTH_SECRET}
      - WHOP_WEBHOOK_SECRET=${WHOP_WEBHOOK_SECRET}
    expose:
      - "3068"
    volumes:
      - api-data:/app/data
      - proxy-quarantine-data:/app/proxy-state
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_started
      redis:
        condition: service_started
    labels:
      - "traefik.docker.network=coolify"

  worker:
    build:
      context: .
      dockerfile: docker/Dockerfile.worker
    container_name: downloadtool-worker
    environment:
      - RUST_LOG=info
      - PROXY_QUARANTINE_FILE=/app/proxy-state/quarantined-proxies.txt
      - DATABASE_URL=postgres://downloadtool:${POSTGRES_PASSWORD}@postgres:5432/downloadtool
      - REDIS_URL=redis://redis:6379
      - MUX_QUEUE_STREAM=${MUX_QUEUE_STREAM}
      - MUX_ARTIFACT_BACKEND=${MUX_ARTIFACT_BACKEND}
      - MUX_ARTIFACT_TTL_SECS=${MUX_ARTIFACT_TTL_SECS}
      - MUX_CLEANUP_INTERVAL_SECS=${MUX_CLEANUP_INTERVAL_SECS}
      - S3_ENDPOINT=${S3_ENDPOINT}
      - S3_BUCKET_NAME=${S3_BUCKET_NAME}
      - S3_ACCESS_KEY_ID=${S3_ACCESS_KEY_ID}
      - S3_SECRET_ACCESS_KEY=${S3_SECRET_ACCESS_KEY}
      - S3_REGION=${S3_REGION}
    volumes:
      - proxy-quarantine-data:/app/proxy-state
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_started
      redis:
        condition: service_started

  frontend:
    build:
      context: .
      dockerfile: docker/Dockerfile.frontend
      args:
        - VITE_API_URL=${VITE_API_URL:-https://api-download.khoadangbui.online}
